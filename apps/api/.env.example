# ============ 云上田园 API 环境变量样例 ============
# 复制为 .env.local 后按本机情况填(.env.local 不入 git)

# 服务端口
PORT=3000

# 数据库 (docker-compose 默认值)
DATABASE_URL="mysql://farmer:farm123@localhost:3306/cloud_farm"

# Redis (可选,P2 起才会用到)
REDIS_URL="redis://localhost:6379"

# JWT 密钥 (生产环境务必改成长串随机)
JWT_SECRET="dev-only-secret-please-change-in-prod"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# 萤石云 OpenAPI (P5 才会用到,先占位)
EZVIZ_APP_KEY=""
EZVIZ_APP_SECRET=""

# OSS / R2 (P5 才会用到,先占位)
OSS_ENDPOINT=""
OSS_BUCKET=""
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
