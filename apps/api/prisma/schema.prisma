// ============ 云上田园 数据库 schema ============
// 跨方言安全:用 SQLite (开发) / MySQL (生产) 都能跑
// 切换方法:把 datasource 的 provider 改成 mysql,DATABASE_URL 改成 mysql://...
// 详见 CLAUDE.md §7 与架构 v2 §4

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"            // ★ 上线切 MySQL 时改这里 + DATABASE_URL
  url      = env("DATABASE_URL")
}

// ============ User ============
// C 端用户 + B 端账号(role 区分)
model User {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  nickname  String   @default("田园用户")
  avatar    String   @default("🧑‍🌾")
  level     String   @default("Lv.1")
  role      String   @default("customer") // customer / agronomist / cs / operator / admin
  // P8 W2: 软禁用,active=false 时 JWT 校验直接拒登,但历史订单还在
  active    Boolean  @default(true)
  // P8 B: 邀请体系
  inviteCode String? @unique           // 用户的邀请码(首次访问邀请页生成)
  invitedBy  Int?                       // 谁邀请的我(对方 user.id)
  openid    String?  @unique
  unionid   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses   Address[]
  orders      Order[]
  userCoupons UserCoupon[]
}

// ============ Coupon(优惠券模板)P8 B ============
model Coupon {
  id        String   @id            // 'cp-newuser-50'
  name      String                  // '新人立减券'
  type      String   @default("discount") // discount(满减) / cash(无门槛现金)
  amount    Int                     // 减免金额(元)
  threshold Int      @default(0)    // 满 X 元可用,0=无门槛
  scope     String   @default("all")// all / adopt(认养) / shop(商城)
  validDays Int      @default(30)   // 领取后有效天数
  desc      String   @default("")
  status    String   @default("active") // active / archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userCoupons UserCoupon[]
}

// ============ UserCoupon(用户持有的券)P8 B ============
model UserCoupon {
  id          String    @id @default(cuid())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  couponId    String
  coupon      Coupon    @relation(fields: [couponId], references: [id])
  status      String    @default("unused") // unused / used / expired
  source      String    @default("system") // system / invite / signup
  grantedAt   DateTime  @default(now())
  expireAt    DateTime
  usedAt      DateTime?
  usedOrderId String?
}

// ============ Address ============
model Address {
  id        String   @id @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  province  String
  city      String
  district  String
  detail    String
  tag       String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ Package(认养套餐) ============
// id 用业务可读字符串(pkg-basic / pkg-pro / pkg-family)
// gallery / highlights / crops 是数组,跨方言安全用 String 存 JSON
model Package {
  id          String   @id // 'pkg-basic' | 'pkg-pro' | 'pkg-family' | ...
  name        String
  area        Int      // 平方米
  price       Int      // 单位:元/年
  tag         String   // '热销' / '推荐' / '亲子'
  cover       String
  gallery     String   // JSON 数组(string[])
  highlights  String   // JSON 数组(string[])
  crops       String   // JSON 数组(string[])
  status      String   @default("active") // active / archived
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]
}

// ============ Plot(地块) ============
model Plot {
  id        String   @id // 'P-A-07'
  block     String   // 'A 区'
  row       Int
  col       Int
  status    String   @default("available") // available / sold / maintenance / reserved
  sunHours  Int      @default(6)
  soilScore Int      @default(85)
  cameraId  String?  @unique
  camera    Camera?  @relation(fields: [cameraId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ Camera(摄像头) ============
// 1 plot 1 camera (P5 接萤石云)
model Camera {
  id           String    @id @default(cuid())
  deviceSerial String    @unique
  vendor       String    @default("ezviz") // ezviz / hikvision / custom
  channelNo    Int       @default(1)
  ptzSupported Boolean   @default(false)
  status       String    @default("offline") // online / offline / maintenance
  lastOnlineAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  plot         Plot?
}

// ============ Order(订单) ============
// 包括认养订单 + 农产品订单(type 区分)
// metadata 存订单类型相关的扩展字段(timeline/logistics/subItems),JSON
model Order {
  id          String   @id // 'ORD-2026-0418'
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  type        String   // '认养' | '产地直送'
  typeIcon    String
  title       String
  cover       String
  price       Int      // 单位:元
  count       Int      @default(1)
  status      String   // pending / paid / shipped / delivering / completed / growing / cancelled
  statusLabel String
  date        DateTime
  packageId   String?
  package     Package? @relation(fields: [packageId], references: [id])
  plotId      String?  // P5-mock: 认养订单关联的地块,方便"我的田"查
  addressId   String?
  metadata    String?  // JSON 字符串
  // 选作物用 JSON 数组存,跨方言安全(同 Package.crops 套路)
  crops       String?
  // 立牌名(亲子版 / 用户起的名字)
  stake       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============ JournalEntry(田园动态) ============
model JournalEntry {
  id        String   @id @default(cuid())
  type      String   // bloom/water/fertilize/weed/shoot/plant/ship/harvest/pest
  icon      String
  title     String
  summary   String
  body      String
  photos    String   // JSON 数组(string[])
  by        String   // 农技员姓名
  at        DateTime
  plotId    String?
  likes     Int      @default(0)
  comments  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ Crop(作物百科) ============
// 农场可种作物清单,展示在 miniapp /pages/crops/
// 每个作物对应推荐套餐(冗余存储 packageRefs JSON 数组,跨方言安全)
model Crop {
  id            String   @id // 'crop-tomato' / 'crop-strawberry' ...
  name          String
  emoji         String
  cover         String
  season        String   // 春秋 / 夏秋 / 冬春 / 春季 / 秋种春收
  difficulty    Int      @default(1) // 1-5 星
  daysToHarvest String
  yieldPerSqm   String
  intro         String
  tags          String   // JSON 数组(string[])
  recommendPkg  String   // JSON 数组(string[]),记套餐名 ('基础版'/'进阶版'/'亲子版')
  status        String   @default("active") // active / archived
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============ PhotoPost(用户照片墙) ============
// 用户晒地块/收获/亲子互动的照片
model PhotoPost {
  id        String   @id // 'pw-001'
  userName  String   // 发布者昵称(冗余存,简化查询)
  userIcon  String   // emoji avatar
  photo     String   // 主图 URL
  caption   String
  plotId    String?
  crop      String?
  likes     Int      @default(0)
  comments  Int      @default(0)
  at        DateTime
  status    String   @default("active") // active / removed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ ErrorLog(前端错误收集) ============
// P8 W2-5: 前端 Vue errorHandler / unhandledrejection 抛错时 POST 过来
// 不挂 user 关联表(防止外键约束让上报失败),只存 userId 数字
model ErrorLog {
  id        Int      @id @default(autoincrement())
  source    String   // 'admin' / 'miniapp'
  message   String
  stack     String   @default("")
  url       String   @default("")
  userAgent String   @default("")
  userId    Int?     // 不强外键,可空
  at        DateTime @default(now())
}

// ============ Command(指令工单) ============
// 用户在"我的田"发的浇水/施肥/拍照等指令
// 农技员在 admin 端执行后回填 photo + completedAt
model Command {
  id          String    @id // 'c-2026-0427-01'
  userId      Int
  type        String    // water / fertilize / weed / shoot
  icon        String
  label       String
  plotId      String
  requestedAt DateTime
  completedAt DateTime?
  status      String    @default("pending") // pending / executing / completed / rejected
  statusLabel String    @default("待执行")
  by          String?   // 农技员姓名
  note        String    @default("")
  photo       String?   // 完成回填照片 URL
  cost        Int       @default(0) // 元
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
